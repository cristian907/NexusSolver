{
  "name": "transport-and-assignment-problem-solver",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo runner for Transport and Assignment Problem Solver",
  "scripts": {
    "backend": "cd Backend && ( [ -d ../.venv ] && ../.venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8000 || ../venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8000 )",
    "frontend": "pnpm --filter problem-solver-frontend dev",
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"pnpm:backend\" \"pnpm:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
